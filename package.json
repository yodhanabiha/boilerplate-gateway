{
  "name": "dynamic-form",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node ./dist/main/index.js",
    "start-trace": "node --require ./dist/instrumentation/instrumentation.js ./dist/main/index.js",
    "build": "rm -rf ./dist && tsc",
    "dev": "nodemon -L ./src/main/index.ts",
    "dev-trace": "nodemon -L --require ./src/trace/instrumentation.ts ./src/main/index.ts",
    "prettier:cli": "prettier \"**/*.ts\" --list-different",
    "prettier:check": "npm run prettier:cli -- -l",
    "prettier:fix": "npm run prettier:cli -- --write",
    "lint": "npm run eslint && npm run prettier:check",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "eslint": "eslint --report-unused-disable-directives .",
    "eslint:fix": "npm run eslint -- --fix",
    "prepare": "husky",
    "husky": "node ./node_modules/husky/bin.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:rollback": "npx sequelize-cli db:migrate:undo",
    "migrate:seed": "npx sequelize-cli db:seed:all"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "keywords": [],
  "author": "FPS",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.48.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@types/minio": "^7.1.1",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^10.0.0",
    "amqplib": "^0.10.7",
    "array-to-tree": "^3.3.2",
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "create-html": "^4.1.0",
    "cron": "^4.4.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.6.0",
    "html-pdf": "^3.0.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mediasoup": "^3.19.14",
    "minio": "^8.0.4",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.2",
    "nodemon": "^3.1.9",
    "pdf-creator-node": "^2.3.5",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "redis": "^4.7.0",
    "sequelize": "^6.37.7",
    "sequelize-typescript": "^2.1.6",
    "sharp": "^0.34.2",
    "socket.io": "^4.8.1",
    "ts-node": "^10.9.2",
    "uuid": "^10.0.0",
    "winston": "^3.13.1",
    "winston-loki": "^6.1.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash": "^4.17.7",
    "@types/nodemailer": "^6.4.17",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-register": "^6.26.0",
    "eslint": "^9.8.0",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.8",
    "sequelize-cli": "^6.6.2",
    "typescript-eslint": "^8.0.0"
  }
}
